# Copy this file to ".env" for LOCAL runs (never commit the real .env).
# On GitHub, set these as repository secrets instead (see README).

# The Gmail address that SENDS the alert.
EMAIL_ADDRESS=youraddress@gmail.com

# A Gmail "App Password" (16 chars, no spaces). NOT your normal password.
# Create one at: https://myaccount.google.com/apppasswords
EMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx

# Where alerts are delivered. Can be the same as EMAIL_ADDRESS.
# Multiple recipients allowed, comma-separated.
EMAIL_TO=youraddress@gmail.com

# Optional — only change if you don't use Gmail.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
